rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Every user's own profile lives here, including their assigned `role`.
    // Roles are only ever set by the setUserRole Cloud Function, which uses
    // the Admin SDK and bypasses these rules entirely — so clients are
    // explicitly blocked from creating or changing the `role` field
    // themselves. NOTE: Firestore rules are OR'd across every matching
    // `match` block for a given path, so this collection deliberately has no
    // other rule matching it (no blanket `{document=**}` catch-all) — that
    // would otherwise re-permit the writes this block exists to block.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId && !('role' in request.resource.data);
      allow update: if request.auth.uid == userId
        && request.resource.data.get('role', null) == resource.data.get('role', null);
    }

    match /patients/{patientId} {
      allow read, write: if request.auth != null;
    }

    match /emsLocations/{locationId} {
      allow read, write: if request.auth != null;
    }
  }
}
